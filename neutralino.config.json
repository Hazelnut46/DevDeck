{
  "applicationId": "js.devdeck.app",
  "version": "1.0.0",
  "defaultMode": "window",
  "port": 0,
  "documentRoot": "/resources/",
  "url": "/",
  "enableServer": true,
  "enableNativeAPI": true,
  "tokenSecurity": "one-time",
  "logging": {
    "enabled": true,
    "writeToLogFile": false
  },
  "nativeBlockList": [],
  "globalVariables": {},
  "modes": {
    "window": {
      "title": "DevDeck",
      "width": 900,
      "height": 620,
      "minWidth": 700,
      "minHeight": 500,
      "resizable": true,
      "borderless": true,
      "alwaysOnTop": false,
      "icon": "/resources/icons/appIcon.png"
    }
  },
  "cli": {
    "binaryName": "devdeck",
    "resourcesPath": "/resources/",
    "extensionsPath": "/extensions/",
    "clientLibrary": "/resources/js/neutralino.js",
    "binaryVersion": "6.1.0",
    "clientVersion": "6.1.0"
  }
}
